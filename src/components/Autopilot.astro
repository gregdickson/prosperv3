---
const stats = [
  {
    number: "73%",
    text: "of Kiwis have never reviewed their KiwiSaver fund type.\n\nNot once.",
  },
  {
    number: "$200k",
    text: "the potential difference between the right fund and the wrong one over a working life",
  },
  {
    number: "3%",
    text: "difference in annual returns between a top performer and a poor one — compounded over decades, it's life-changing",
  },
];
---

<section class="max-w-[1440px] mx-auto px-[40px] mt-[100px]">
  <!-- Blue background panel -->
  <div class="bg-blue rounded-[6px] px-[115px] py-[76px] text-center">
    <h2 class="font-tight text-[96px] leading-[106px] uppercase text-dark mb-[94px]">
      KiwiSaver is too important to leave on autopilot.
    </h2>
    <p class="font-tight text-[48px] leading-[55px] uppercase text-dark max-w-[1130px] mx-auto">
      Unlock the opportunity in your KiwiSaver with clear advice, no jargon, and a plan built to perform.
    </p>
    <p class="font-tight text-[48px] leading-[55px] uppercase text-dark max-w-[1130px] mx-auto mt-[55px]">
      In two minutes, you can get a quick read on whether your KiwiSaver is doing what it should — and what to do next if it's not.
    </p>
  </div>

  <!-- Stat cards -->
  <div class="grid grid-cols-3 gap-[20px] mt-[22px]">
    {stats.map((stat) => (
      <div class="bg-white border-[6px] border-dark rounded-[6px] px-[40px] py-[138px] text-center">
        <p class="font-narrow text-[110px] leading-[55px] uppercase text-blue tracking-[-1.1px] mb-[104px]">
          {stat.number}
        </p>
        <p class="font-tight text-[36px] leading-[46px] uppercase text-dark whitespace-pre-line">
          {stat.text}
        </p>
      </div>
    ))}
  </div>
</section>
