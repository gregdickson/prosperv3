---
const stats = [
  {
    number: "73%",
    text: "of Kiwis have never reviewed their KiwiSaver fund type.\n\nNot once.",
  },
  {
    number: "$200k",
    text: "the potential difference between the right fund and the wrong one over a working life",
  },
  {
    number: "3%",
    text: "difference in annual returns between a top performer and a poor one — compounded over decades, it's life-changing",
  },
];
---

<section class="max-w-[1440px] mx-auto px-5 md:px-[40px] mt-[60px] md:mt-[100px]">
  <!-- Blue background panel -->
  <div class="bg-blue rounded-[6px] px-6 md:px-[60px] lg:px-[115px] py-[40px] md:py-[76px] text-center">
    <h2 class="font-tight text-[40px] md:text-[64px] lg:text-[96px] leading-[1.1] uppercase text-dark mb-[40px] md:mb-[94px]">
      KiwiSaver is too important to leave on autopilot.
    </h2>
    <p class="font-tight text-[22px] md:text-[36px] lg:text-[48px] leading-[1.15] uppercase text-dark max-w-[1130px] mx-auto">
      Unlock the opportunity in your KiwiSaver with clear advice, no jargon, and a plan built to perform.
    </p>
    <p class="font-tight text-[22px] md:text-[36px] lg:text-[48px] leading-[1.15] uppercase text-dark max-w-[1130px] mx-auto mt-[30px] md:mt-[55px]">
      In two minutes, you can get a quick read on whether your KiwiSaver is doing what it should — and what to do next if it's not.
    </p>
  </div>

  <!-- Stat cards -->
  <div class="grid grid-cols-1 md:grid-cols-3 gap-[20px] mt-[22px]">
    {stats.map((stat) => (
      <div class="bg-white border-[6px] border-dark rounded-[6px] px-6 md:px-[40px] py-[60px] md:py-[138px] text-center">
        <p class="font-narrow text-[64px] md:text-[80px] lg:text-[110px] leading-[1] uppercase text-blue tracking-[-1.1px] mb-[40px] md:mb-[104px]">
          {stat.number}
        </p>
        <p class="font-tight text-[22px] md:text-[28px] lg:text-[36px] leading-[1.3] uppercase text-dark whitespace-pre-line">
          {stat.text}
        </p>
      </div>
    ))}
  </div>
</section>
