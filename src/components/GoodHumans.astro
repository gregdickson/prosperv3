---
import Button from "./Button.astro";
---

<section class="border-y-[6px] border-dark-alt bg-cream mt-[100px]" id="about">
  <div class="max-w-[1440px] mx-auto px-[40px] py-[51px]">
    <div class="flex gap-[134px]">
      <!-- Photo -->
      <div class="w-[555px] h-[1020px] rounded-[6px] overflow-hidden flex-shrink-0">
        <div class="w-full h-full bg-teal/30 flex items-center justify-center">
          <span class="font-tight text-[24px] uppercase text-dark/50">JP & Nick Photo</span>
        </div>
      </div>

      <!-- Content -->
      <div class="flex flex-col justify-start pt-[25px]">
        <h2 class="font-tight text-[64px] leading-[74px] uppercase text-dark mb-[68px]">
          Clear advice from good humans.
        </h2>

        <p class="font-tight text-[36px] leading-[46px] uppercase text-dark mb-[68px]">
          Prosper was built to make KiwiSaver easier to understand and easier to act on. JP and Nick bring smart thinking, practical advice, and a more human approach to a category that often makes simple things feel harder than they need to be. No pressure. No jargon. No making you feel behind. Just clear guidance to help you make better decisions.
        </p>

        <Button label="Say g'day to JP and Nick " href="#contact" />
      </div>
    </div>
  </div>
</section>
