---
import Button from "./Button.astro";
---

<section class="max-w-[1440px] mx-auto px-5 md:px-[40px]">
  <!-- Main headline -->
  <h1 class="font-tight text-[48px] md:text-[80px] lg:text-[120px] leading-[1] uppercase text-dark text-center mt-[60px] md:mt-[120px] mb-[40px] md:mb-[80px] tracking-[-1px] md:tracking-[-2px]">
    KIWISAVER: SORTED
  </h1>

  <!-- Sub-copy -->
  <div class="max-w-[1130px] mx-auto text-center mb-[40px] md:mb-[80px]">
    <p class="font-tight text-[24px] md:text-[36px] lg:text-[48px] leading-[1.15] uppercase text-dark">
      Unlock the opportunity in your KiwiSaver with clear advice, no jargon, and a plan built to perform.
    </p>
    <p class="font-tight text-[24px] md:text-[36px] lg:text-[48px] leading-[1.15] uppercase text-dark mt-[30px] md:mt-[55px]">
      In two minutes, you can get a quick read on whether your KiwiSaver is doing what it should — and what to do next if it's not.
    </p>
  </div>

  <!-- CTAs -->
  <div class="flex flex-col md:flex-row items-center justify-between gap-6 md:gap-0 max-w-[1130px] mx-auto">
    <Button label="CHECK MY FUND" href="#health-check" />
    <!-- Center icon -->
    <img src="/icon.svg" alt="Prosper" class="w-[48px] h-[36px] md:w-[64px] md:h-[48px] hidden md:block" />
    <Button label="BOOK A REVIEW" href="#book" />
  </div>
</section>
