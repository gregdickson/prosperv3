<section class="max-w-[1440px] mx-auto px-5 md:px-[40px] mt-[60px] md:mt-[100px]" id="how-it-works">
  <!-- Top panel -->
  <div class="bg-yellow rounded-[6px] px-6 md:px-[60px] lg:px-[115px] py-[40px] md:py-[76px] text-center">
    <h2 class="font-tight text-[36px] md:text-[64px] lg:text-[96px] leading-[1.1] uppercase text-dark mb-[40px] md:mb-[94px]">
      The Double Pump: A better way to sort your KiwiSaver.
    </h2>
    <p class="font-tight text-[22px] md:text-[36px] lg:text-[48px] leading-[1.15] uppercase text-dark max-w-[1130px] mx-auto">
      Most advisers jump straight to recommending a provider (usually one they're affiliated with). We reckon that's backwards.
    </p>
  </div>

  <!-- Two step cards -->
  <div class="grid grid-cols-1 md:grid-cols-2 gap-[21px] mt-[18px]">
    <!-- Step 1 -->
    <div class="bg-white border-[6px] border-dark rounded-[6px] px-6 md:px-[55px] py-[40px] md:py-[59px] text-center">
      <div class="w-[100px] h-[100px] md:w-[164px] md:h-[166px] mx-auto mb-[30px] md:mb-[48px] rounded-full border-[6px] border-dark flex items-center justify-center">
        <span class="font-tight text-[36px] md:text-[54px] uppercase text-dark">1</span>
      </div>
      <p class="font-tight text-[22px] md:text-[28px] lg:text-[36px] leading-[1.5] uppercase text-dark">
        we get to know you: where you're at, what matters to you, what your KiwiSaver is doing now, and where it might need work.
      </p>
    </div>

    <!-- Step 2 -->
    <div class="bg-white border-[6px] border-dark rounded-[6px] px-6 md:px-[55px] py-[40px] md:py-[59px] text-center">
      <div class="w-[100px] h-[100px] md:w-[164px] md:h-[166px] mx-auto mb-[30px] md:mb-[48px] rounded-full border-[6px] border-dark flex items-center justify-center">
        <span class="font-tight text-[36px] md:text-[54px] uppercase text-dark">2</span>
      </div>
      <p class="font-tight text-[22px] md:text-[28px] lg:text-[36px] leading-[1.5] uppercase text-dark">
        Then, once the strategy is clear, we match that to the right provider and setup.
      </p>
    </div>
  </div>

  <!-- Summary bar -->
  <div class="bg-blue rounded-[6px] px-6 md:px-[60px] lg:px-[115px] py-[30px] md:py-[43px] text-center mt-[18px]">
    <p class="font-tight text-[22px] md:text-[36px] lg:text-[48px] leading-[1.35] uppercase text-dark max-w-[1130px] mx-auto">
      It is a simple idea, but it changes everything: strategy first, provider second.
    </p>
  </div>

  <!-- Bottom image -->
  <div class="w-full h-[250px] md:h-[574px] rounded-[6px] overflow-hidden mt-[18px]">
    <img src="/images/nz-mountains.jpg" alt="Person looking out over New Zealand mountains at sunset" class="w-full h-full object-cover" />
  </div>
</section>
