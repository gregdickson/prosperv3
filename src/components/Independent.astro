---
const badges = [
  { label: "FMA Registered" },
  { label: "100% Independent" },
  { label: "Free reviews" },
];
---

<section class="max-w-[1440px] mx-auto px-5 md:px-[40px] mt-[60px] md:mt-[100px]">
  <!-- Heading -->
  <div class="max-w-[1130px] mx-auto mb-[50px] md:mb-[107px] md:px-[115px]">
    <h2 class="font-tight text-[36px] md:text-[64px] lg:text-[96px] leading-[1.1] uppercase text-dark mb-[40px] md:mb-[107px]">
      Independent. Free to review. Properly qualified.
    </h2>
    <p class="font-tight text-[22px] md:text-[36px] lg:text-[48px] leading-[1.15] uppercase text-dark">
      Everything we do is built to be straightforward, transparent, and in your corner.
    </p>
  </div>

  <!-- Badges row -->
  <div class="flex flex-col md:flex-row items-center justify-between gap-6 md:gap-0 max-w-[1335px] mx-auto mb-[60px] md:mb-[131px]">
    {badges.map((badge, i) => (
      <div class="flex items-center gap-6 md:gap-[83px]">
        {i > 0 && (
          <img src="/icon.svg" alt="" class="w-[48px] h-[36px] md:w-[64px] md:h-[48px] hidden md:block" />
        )}
        <span class="font-tight text-[24px] md:text-[30px] lg:text-[36px] leading-[1.3] uppercase text-dark">
          {badge.label}
        </span>
      </div>
    ))}
  </div>

  <!-- Image -->
  <div class="w-full h-[250px] md:h-[500px] lg:h-[686px] rounded-[6px] overflow-hidden">
    <img src="/images/ocean-overlook.jpg" alt="Friends sitting on a hilltop overlooking the New Zealand coast" class="w-full h-full object-cover" />
  </div>
</section>
