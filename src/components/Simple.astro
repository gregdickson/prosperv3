---
import Button from "./Button.astro";
---

<section class="border-y-[6px] border-dark-alt bg-cream mt-[100px]">
  <div class="max-w-[1440px] mx-auto px-[40px] py-[50px]">
    <div class="flex gap-[134px]">
      <!-- Image -->
      <div class="w-[555px] h-[953px] rounded-[6px] overflow-hidden flex-shrink-0">
        <div class="w-full h-full bg-teal/30 flex items-center justify-center">
          <span class="font-tight text-[24px] uppercase text-dark/50">Photo placeholder</span>
        </div>
      </div>

      <!-- Content -->
      <div class="flex flex-col justify-start pt-[26px]">
        <h2 class="font-tight text-[64px] leading-[74px] uppercase text-dark mb-[168px]">
          We keep it simple,<br />because it should be.
        </h2>

        <div class="font-tight text-[36px] leading-[46px] uppercase text-dark space-y-[46px] mb-[68px]">
          <p>We're here to make KiwiSaver feel less like a chore and more like an opportunity.</p>
          <p>We help people understand what they have, what it is doing, and what they could do better — without the waffle, the pressure, or the finance-chat weirdness.</p>
          <p>The goal is simple: help more Kiwis feel confident, clear, and in control of something that can have a big impact on their future.</p>
        </div>

        <Button label="BOOK A REVIEW" href="#book" />
      </div>
    </div>
  </div>
</section>
