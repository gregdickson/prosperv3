<footer class="bg-dark text-cream">
  <div class="max-w-[1440px] mx-auto px-5 md:px-[40px] py-[40px] md:py-[66px]">
    <!-- Top row -->
    <div class="flex flex-col md:flex-row justify-between gap-[40px] md:gap-0 mb-[60px] md:mb-[100px]">
      <!-- Logo -->
      <a href="/">
        <img src="/logo.svg" alt="Prosper" class="w-[160px] md:w-[209px] h-auto" style="filter: invert(1);" />
      </a>

      <!-- Nav columns -->
      <div class="grid grid-cols-2 md:flex gap-8 md:gap-[139px]">
        <div class="flex flex-col gap-[16px] md:gap-[23px] font-tight text-[18px] md:text-[24px] uppercase">
          <a href="#about" class="hover:opacity-70 transition-opacity">About</a>
          <a href="#how-it-works" class="hover:opacity-70 transition-opacity">How It Works</a>
          <a href="#contact" class="hover:opacity-70 transition-opacity">Contact</a>
        </div>
        <div class="flex flex-col gap-[16px] md:gap-[23px] font-tight text-[18px] md:text-[24px] uppercase">
          <a href="#health-check" class="hover:opacity-70 transition-opacity">Health Check</a>
          <a href="#first-home" class="hover:opacity-70 transition-opacity">First Home Buyers</a>
          <a href="#retirement" class="hover:opacity-70 transition-opacity">Saving for Retirement</a>
          <a href="#business" class="hover:opacity-70 transition-opacity">Business Owners</a>
          <a href="#resources" class="hover:opacity-70 transition-opacity">Resources</a>
        </div>
        <div class="flex flex-col gap-[16px] md:gap-[23px] font-tight text-[18px] md:text-[24px] uppercase">
          <a href="#privacy" class="hover:opacity-70 transition-opacity">Privacy Policy</a>
          <a href="#disclaimer" class="hover:opacity-70 transition-opacity">Disclaimer</a>
        </div>
      </div>
    </div>

    <!-- Divider -->
    <div class="w-full h-px bg-cream/30 mb-[20px] md:mb-[27px]"></div>

    <!-- Disclaimer text -->
    <p class="font-tight text-[12px] md:text-[14px] leading-[1.5] text-cream/80 mb-[40px] md:mb-[69px] max-w-[1015px]">
      Prosper Financial Ltd is a registered Financial Advice Provider (FSP FS1007548) with the Financial Markets Authority (FMA) of New Zealand. The information on this website is general in nature and does not constitute personalised financial advice. Please refer to our disclosure statement for more information.
    </p>

    <!-- Divider -->
    <div class="w-full h-px bg-cream/30 mb-[20px] md:mb-[27px]"></div>

    <!-- Copyright -->
    <p class="font-tight text-[14px] md:text-[16px] text-cream/80">
      &copy; 2026 Prosper Financial Ltd. All rights reserved.
    </p>
  </div>
</footer>
