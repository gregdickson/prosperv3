---
import Layout from '../layouts/Layout.astro';
import Nav from '../components/Nav.astro';
import Button from '../components/Button.astro';
import Footer from '../components/Footer.astro';
---

<Layout title="About Prosper — KiwiSaver: Sorted">
  <Nav />

  <!-- Hero -->
  <section class="max-w-[1440px] mx-auto px-5 md:px-[40px] mt-[60px] md:mt-[100px] mb-[40px] md:mb-[60px]">
    <div class="text-center max-w-[900px] mx-auto">
      <h1 class="font-tight text-[40px] md:text-[64px] lg:text-[96px] leading-[1.1] uppercase text-dark mb-[20px] md:mb-[40px]">
        Clear advice from good humans.
      </h1>
      <p class="font-tight text-[20px] md:text-[28px] lg:text-[36px] leading-[1.3] uppercase text-dark">
        No pressure. No jargon. Just straight-up guidance to help you make better decisions with your KiwiSaver.
      </p>
    </div>
  </section>

  <!-- Meet JP & Nick -->
  <section class="max-w-[1440px] mx-auto px-5 md:px-[40px] mb-[60px] md:mb-[100px]">
    <h2 class="font-tight text-[36px] md:text-[48px] lg:text-[64px] leading-[1.15] uppercase text-dark mb-[30px] md:mb-[50px] text-center">
      Meet JP & Nick
    </h2>

    <!-- JP -->
    <div class="border-y-[6px] border-dark-alt bg-cream rounded-[6px] mb-[30px] md:mb-[40px]">
      <div class="px-5 md:px-[40px] py-[30px] md:py-[51px]">
        <div class="flex flex-col md:flex-row gap-[30px] md:gap-[60px]">
          <!-- Photo -->
          <div class="w-full md:w-[400px] h-[400px] md:h-[500px] rounded-[6px] overflow-hidden flex-shrink-0">
            <img src="/images/jp.png" alt="Jarred Percival — Director & Senior Financial Adviser at Prosper" class="w-full h-full object-cover" />
          </div>

          <!-- Content -->
          <div class="flex flex-col justify-center">
            <h3 class="font-tight text-[28px] md:text-[36px] lg:text-[48px] leading-[1.15] uppercase text-dark mb-[8px]">
              Jarred Percival
            </h3>
            <p class="font-tight text-[18px] md:text-[22px] leading-[1.3] uppercase text-dark/60 mb-[20px] md:mb-[30px]">
              Director & Senior Financial Adviser
            </p>

            <p class="font-tight text-[18px] md:text-[24px] leading-[1.3] uppercase text-dark mb-[16px] md:mb-[24px]">
              JP — or Jarred when he's in trouble — is a proud Cantab, born and bred in Christchurch. Life, for him, revolves around two things: sport and investments.
            </p>
            <p class="font-tight text-[18px] md:text-[24px] leading-[1.3] uppercase text-dark mb-[16px] md:mb-[24px]">
              He has represented New Zealand in U85kg rugby, played for the NZ Heartland XV rugby team and the NZ Hawks AFL team, and in more recent years has completed the Coast to Coast multiple times.
            </p>
            <p class="font-tight text-[18px] md:text-[24px] leading-[1.3] uppercase text-dark mb-[16px] md:mb-[24px]">
              JP founded Prosper after gaining experience with another advice firm and seeing an opportunity to do things differently. He is passionate about making financial advice more accessible to everyday Kiwis, and is on a mission to make KiwiSaver and investing feel relatable, easy to understand, and genuinely enjoyable.
            </p>
            <p class="font-tight text-[18px] md:text-[24px] leading-[1.3] uppercase text-dark">
              Outside of work, you'll usually find him listening to a good podcast or standing on top of a mountain somewhere.
            </p>
          </div>
        </div>
      </div>
    </div>

    <!-- Nick -->
    <div class="border-y-[6px] border-dark-alt bg-cream rounded-[6px]">
      <div class="px-5 md:px-[40px] py-[30px] md:py-[51px]">
        <div class="flex flex-col md:flex-row-reverse gap-[30px] md:gap-[60px]">
          <!-- Photo -->
          <div class="w-full md:w-[400px] h-[400px] md:h-[500px] rounded-[6px] overflow-hidden flex-shrink-0">
            <img src="/images/nick.png" alt="Nick Kwant — Head of Growth & Strategy at Prosper" class="w-full h-full object-cover" />
          </div>

          <!-- Content -->
          <div class="flex flex-col justify-center">
            <h3 class="font-tight text-[28px] md:text-[36px] lg:text-[48px] leading-[1.15] uppercase text-dark mb-[8px]">
              Nick Kwant
            </h3>
            <p class="font-tight text-[18px] md:text-[22px] leading-[1.3] uppercase text-dark/60 mb-[20px] md:mb-[30px]">
              Head of Growth & Strategy
            </p>

            <p class="font-tight text-[18px] md:text-[24px] leading-[1.3] uppercase text-dark mb-[16px] md:mb-[24px]">
              Nick grew up in Christchurch, spent time in Dunedin and Wellington, and is now settled in the Hawke's Bay. Like JP, his interests have long revolved around sport and investments.
            </p>
            <p class="font-tight text-[18px] md:text-[24px] leading-[1.3] uppercase text-dark mb-[16px] md:mb-[24px]">
              After playing professional cricket for Canterbury, Otago, and in the UK, Nick moved into the business world and built a strong career in sales before joining his longtime mate in the financial services industry.
            </p>
            <p class="font-tight text-[18px] md:text-[24px] leading-[1.3] uppercase text-dark mb-[16px] md:mb-[24px]">
              Nick is passionate about reframing how everyday Kiwis think about financial advice. He believes it does not need to feel intimidating, time-consuming, boring, or reserved for the wealthy. His focus is on helping make good advice feel more human, more approachable, and more useful in real life.
            </p>
            <p class="font-tight text-[18px] md:text-[24px] leading-[1.3] uppercase text-dark">
              Outside of work, you'll likely find him in the kitchen or reading a good book.
            </p>
          </div>
        </div>
      </div>
    </div>

    <div class="text-center mt-[30px] md:mt-[50px]">
      <Button label="Say g'day to JP and Nick" href="/contact" />
    </div>
  </section>

  <!-- Values -->
  <section class="max-w-[1440px] mx-auto px-5 md:px-[40px] mb-[60px] md:mb-[100px]">
    <div class="grid grid-cols-1 md:grid-cols-3 gap-[30px] md:gap-[40px]">
      <div class="bg-cream border-[3px] border-dark-alt rounded-[6px] p-6 md:p-10">
        <h3 class="font-tight text-[28px] md:text-[36px] leading-[1.15] uppercase text-dark mb-[16px] md:mb-[24px]">
          Independent
        </h3>
        <p class="font-tight text-[18px] md:text-[24px] leading-[1.3] uppercase text-dark">
          We're not tied to any provider. That means our advice is always in your best interest — not someone else's bottom line.
        </p>
      </div>
      <div class="bg-cream border-[3px] border-dark-alt rounded-[6px] p-6 md:p-10">
        <h3 class="font-tight text-[28px] md:text-[36px] leading-[1.15] uppercase text-dark mb-[16px] md:mb-[24px]">
          Straight up
        </h3>
        <p class="font-tight text-[18px] md:text-[24px] leading-[1.3] uppercase text-dark">
          We explain things clearly and simply. If something doesn't make sense, we'll keep going until it does.
        </p>
      </div>
      <div class="bg-cream border-[3px] border-dark-alt rounded-[6px] p-6 md:p-10">
        <h3 class="font-tight text-[28px] md:text-[36px] leading-[1.15] uppercase text-dark mb-[16px] md:mb-[24px]">
          No pressure
        </h3>
        <p class="font-tight text-[18px] md:text-[24px] leading-[1.3] uppercase text-dark">
          We're here to help you feel confident about your KiwiSaver — not to sell you something you don't need.
        </p>
      </div>
    </div>
  </section>

  <!-- FMA Badge -->
  <section class="max-w-[1440px] mx-auto px-5 md:px-[40px] mb-[60px] md:mb-[100px]">
    <div class="bg-teal rounded-[6px] px-6 md:px-[60px] lg:px-[115px] py-[40px] md:py-[76px] text-center">
      <h2 class="font-tight text-[36px] md:text-[48px] lg:text-[64px] leading-[1.1] uppercase text-dark mb-[20px] md:mb-[40px]">
        Registered & regulated
      </h2>
      <p class="font-tight text-[20px] md:text-[28px] lg:text-[36px] leading-[1.3] uppercase text-dark max-w-[900px] mx-auto mb-[40px] md:mb-[60px]">
        Prosper Financial Ltd is a registered Financial Advice Provider (FSP FS1007548) with the Financial Markets Authority (FMA) of New Zealand.
      </p>
      <Button label="Book a free chat" href="/contact" />
    </div>
  </section>

  <Footer />
</Layout>
