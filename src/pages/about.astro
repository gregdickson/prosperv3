---
import Layout from '../layouts/Layout.astro';
import Nav from '../components/Nav.astro';
import Button from '../components/Button.astro';
import Footer from '../components/Footer.astro';
---

<Layout title="About Prosper — KiwiSaver: Sorted">
  <Nav />

  <!-- Hero -->
  <section class="max-w-[1440px] mx-auto px-5 md:px-[40px] mt-[60px] md:mt-[100px] mb-[40px] md:mb-[60px]">
    <div class="text-center max-w-[900px] mx-auto">
      <h1 class="font-tight text-[40px] md:text-[64px] lg:text-[96px] leading-[1.1] uppercase text-dark mb-[20px] md:mb-[40px]">
        Clear advice from good humans.
      </h1>
      <p class="font-tight text-[20px] md:text-[28px] lg:text-[36px] leading-[1.3] uppercase text-dark">
        No pressure. No jargon. Just straight-up guidance to help you make better decisions with your KiwiSaver.
      </p>
    </div>
  </section>

  <!-- JP & Nick -->
  <section class="max-w-[1440px] mx-auto px-5 md:px-[40px] mb-[60px] md:mb-[100px]">
    <div class="border-y-[6px] border-dark-alt bg-cream rounded-[6px]">
      <div class="px-5 md:px-[40px] py-[30px] md:py-[51px]">
        <div class="flex flex-col md:flex-row gap-[40px] md:gap-[134px]">
          <!-- Photo -->
          <div class="w-full md:w-[555px] h-[400px] md:h-[1020px] rounded-[6px] overflow-hidden flex-shrink-0">
            <div class="w-full h-full bg-teal/30 flex items-center justify-center">
              <span class="font-tight text-[20px] md:text-[24px] uppercase text-dark/50">JP & Nick Photo</span>
            </div>
          </div>

          <!-- Content -->
          <div class="flex flex-col justify-start md:pt-[25px]">
            <h2 class="font-tight text-[36px] md:text-[48px] lg:text-[64px] leading-[1.15] uppercase text-dark mb-[30px] md:mb-[68px]">
              Meet JP & Nick
            </h2>

            <p class="font-tight text-[20px] md:text-[28px] lg:text-[36px] leading-[1.3] uppercase text-dark mb-[30px] md:mb-[68px]">
              Prosper was built to make KiwiSaver easier to understand and easier to act on. JP and Nick bring smart thinking, practical advice, and a more human approach to a category that often makes simple things feel harder than they need to be. No pressure. No jargon. No making you feel behind. Just clear guidance to help you make better decisions.
            </p>

            <Button label="Say g'day to JP and Nick" href="/contact" />
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Values -->
  <section class="max-w-[1440px] mx-auto px-5 md:px-[40px] mb-[60px] md:mb-[100px]">
    <div class="grid grid-cols-1 md:grid-cols-3 gap-[30px] md:gap-[40px]">
      <div class="bg-cream border-[3px] border-dark-alt rounded-[6px] p-6 md:p-10">
        <h3 class="font-tight text-[28px] md:text-[36px] leading-[1.15] uppercase text-dark mb-[16px] md:mb-[24px]">
          Independent
        </h3>
        <p class="font-tight text-[18px] md:text-[24px] leading-[1.3] uppercase text-dark">
          We're not tied to any provider. That means our advice is always in your best interest — not someone else's bottom line.
        </p>
      </div>
      <div class="bg-cream border-[3px] border-dark-alt rounded-[6px] p-6 md:p-10">
        <h3 class="font-tight text-[28px] md:text-[36px] leading-[1.15] uppercase text-dark mb-[16px] md:mb-[24px]">
          Straight up
        </h3>
        <p class="font-tight text-[18px] md:text-[24px] leading-[1.3] uppercase text-dark">
          We explain things clearly and simply. If something doesn't make sense, we'll keep going until it does.
        </p>
      </div>
      <div class="bg-cream border-[3px] border-dark-alt rounded-[6px] p-6 md:p-10">
        <h3 class="font-tight text-[28px] md:text-[36px] leading-[1.15] uppercase text-dark mb-[16px] md:mb-[24px]">
          No pressure
        </h3>
        <p class="font-tight text-[18px] md:text-[24px] leading-[1.3] uppercase text-dark">
          We're here to help you feel confident about your KiwiSaver — not to sell you something you don't need.
        </p>
      </div>
    </div>
  </section>

  <!-- FMA Badge -->
  <section class="max-w-[1440px] mx-auto px-5 md:px-[40px] mb-[60px] md:mb-[100px]">
    <div class="bg-teal rounded-[6px] px-6 md:px-[60px] lg:px-[115px] py-[40px] md:py-[76px] text-center">
      <h2 class="font-tight text-[36px] md:text-[48px] lg:text-[64px] leading-[1.1] uppercase text-dark mb-[20px] md:mb-[40px]">
        Registered & regulated
      </h2>
      <p class="font-tight text-[20px] md:text-[28px] lg:text-[36px] leading-[1.3] uppercase text-dark max-w-[900px] mx-auto mb-[40px] md:mb-[60px]">
        Prosper Financial Ltd is a registered Financial Advice Provider (FSP FS1007548) with the Financial Markets Authority (FMA) of New Zealand.
      </p>
      <Button label="Book a free chat" href="/contact" />
    </div>
  </section>

  <Footer />
</Layout>
