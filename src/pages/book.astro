---
import Layout from '../layouts/Layout.astro';
import Nav from '../components/Nav.astro';
import Button from '../components/Button.astro';
import Footer from '../components/Footer.astro';
---

<Layout title="Book a Free Chat — Prosper">
  <Nav />

  <!-- Hero -->
  <section class="max-w-[1440px] mx-auto px-5 md:px-[40px] mt-[60px] md:mt-[100px] mb-[40px] md:mb-[60px]">
    <div class="text-center max-w-[900px] mx-auto">
      <h1 class="font-tight text-[40px] md:text-[64px] lg:text-[96px] leading-[1.1] uppercase text-dark mb-[20px] md:mb-[40px]">
        15 minutes that could be worth $200,000.
      </h1>
      <p class="font-tight text-[20px] md:text-[28px] lg:text-[36px] leading-[1.3] uppercase text-dark">
        Most Kiwis have never had a proper look at their KiwiSaver. Book a free call with Nick and JP and find out exactly where you stand.
      </p>
    </div>
  </section>

  <!-- Value Props -->
  <section class="max-w-[1440px] mx-auto px-5 md:px-[40px] mb-[60px] md:mb-[100px]">
    <div class="grid grid-cols-1 md:grid-cols-3 gap-[30px] md:gap-[40px]">
      <div class="bg-cream border-[3px] border-dark-alt rounded-[6px] p-6 md:p-10 text-center">
        <h3 class="font-tight text-[28px] md:text-[36px] leading-[1.15] uppercase text-dark mb-[16px] md:mb-[24px]">
          15 minutes
        </h3>
        <p class="font-tight text-[18px] md:text-[24px] leading-[1.3] uppercase text-dark">
          Quick, focused, and respectful of your time. We get straight to what matters.
        </p>
      </div>
      <div class="bg-cream border-[3px] border-dark-alt rounded-[6px] p-6 md:p-10 text-center">
        <h3 class="font-tight text-[28px] md:text-[36px] leading-[1.15] uppercase text-dark mb-[16px] md:mb-[24px]">
          Both of us on the call
        </h3>
        <p class="font-tight text-[18px] md:text-[24px] leading-[1.3] uppercase text-dark">
          You'll chat with both Nick and JP — two heads are better than one when it comes to your money.
        </p>
      </div>
      <div class="bg-cream border-[3px] border-dark-alt rounded-[6px] p-6 md:p-10 text-center">
        <h3 class="font-tight text-[28px] md:text-[36px] leading-[1.15] uppercase text-dark mb-[16px] md:mb-[24px]">
          100% Independent
        </h3>
        <p class="font-tight text-[18px] md:text-[24px] leading-[1.3] uppercase text-dark">
          We're not tied to any provider. Our only job is finding what's best for you.
        </p>
      </div>
    </div>
  </section>

  <!-- What we'll cover -->
  <section class="max-w-[1440px] mx-auto px-5 md:px-[40px] mb-[60px] md:mb-[100px]">
    <div class="bg-cream border-[3px] border-dark-alt rounded-[6px] p-6 md:p-10 lg:p-16">
      <h2 class="font-tight text-[36px] md:text-[48px] lg:text-[64px] leading-[1.1] uppercase text-dark mb-[30px] md:mb-[50px] text-center">
        What we'll cover
      </h2>
      <div class="grid grid-cols-1 sm:grid-cols-2 gap-[16px] md:gap-[24px] max-w-[800px] mx-auto">
        <div class="flex items-start gap-[12px]">
          <span class="font-tight text-[20px] md:text-[24px] text-dark mt-[2px]">-</span>
          <span class="font-tight text-[18px] md:text-[24px] leading-[1.3] uppercase text-dark">Whether your fund type is right for your age and goals</span>
        </div>
        <div class="flex items-start gap-[12px]">
          <span class="font-tight text-[20px] md:text-[24px] text-dark mt-[2px]">-</span>
          <span class="font-tight text-[18px] md:text-[24px] leading-[1.3] uppercase text-dark">How your provider's returns stack up against the market</span>
        </div>
        <div class="flex items-start gap-[12px]">
          <span class="font-tight text-[20px] md:text-[24px] text-dark mt-[2px]">-</span>
          <span class="font-tight text-[18px] md:text-[24px] leading-[1.3] uppercase text-dark">Your contribution rate and whether you're leaving money on the table</span>
        </div>
        <div class="flex items-start gap-[12px]">
          <span class="font-tight text-[20px] md:text-[24px] text-dark mt-[2px]">-</span>
          <span class="font-tight text-[18px] md:text-[24px] leading-[1.3] uppercase text-dark">A clear, honest recommendation — no strings attached</span>
        </div>
      </div>
    </div>
  </section>

  <!-- Meet the team -->
  <section class="max-w-[1440px] mx-auto px-5 md:px-[40px] mb-[60px] md:mb-[100px]">
    <div class="text-center mb-[40px] md:mb-[60px]">
      <h2 class="font-tight text-[36px] md:text-[48px] lg:text-[64px] leading-[1.1] uppercase text-dark mb-[16px]">
        You'll be chatting with us
      </h2>
      <p class="font-tight text-[20px] md:text-[28px] leading-[1.3] uppercase text-dark max-w-[700px] mx-auto">
        No call centres, no juniors, no runaround. Just a straight-up conversation with the two blokes who started Prosper.
      </p>
    </div>
    <div class="flex flex-col sm:flex-row items-center justify-center gap-[40px] md:gap-[80px]">
      <div class="text-center">
        <div class="w-[120px] h-[120px] md:w-[160px] md:h-[160px] rounded-full bg-teal/30 mx-auto mb-[16px] flex items-center justify-center">
          <span class="font-tight text-[16px] uppercase text-dark/50">Nick</span>
        </div>
        <p class="font-tight text-[24px] md:text-[30px] uppercase text-dark">Nick</p>
        <p class="font-tight text-[16px] md:text-[20px] uppercase text-dark/60">Head of Growth</p>
      </div>
      <span class="font-tight text-[36px] md:text-[48px] text-dark hidden sm:block">&</span>
      <div class="text-center">
        <div class="w-[120px] h-[120px] md:w-[160px] md:h-[160px] rounded-full bg-teal/30 mx-auto mb-[16px] flex items-center justify-center">
          <span class="font-tight text-[16px] uppercase text-dark/50">JP</span>
        </div>
        <p class="font-tight text-[24px] md:text-[30px] uppercase text-dark">JP</p>
        <p class="font-tight text-[16px] md:text-[20px] uppercase text-dark/60">Founder & Financial Adviser</p>
      </div>
    </div>
  </section>

  <!-- Booking Widget -->
  <section class="max-w-[1440px] mx-auto px-5 md:px-[40px] mb-[60px] md:mb-[100px]">
    <div class="bg-blue rounded-[6px] p-6 md:p-12 lg:p-16">
      <div class="text-center mb-[40px]">
        <h2 class="font-tight text-[36px] md:text-[48px] lg:text-[64px] leading-[1.1] uppercase text-dark mb-[16px]">
          Pick a time that works for you
        </h2>
        <p class="font-tight text-[20px] md:text-[24px] leading-[1.3] uppercase text-dark max-w-[600px] mx-auto">
          It takes 15 minutes and could change the next 30 years.
        </p>
      </div>
      <div class="bg-white rounded-[6px] p-4 md:p-6">
        <iframe
          src="https://tr.tilw.co.uk/widget/booking/ClcSvw6h2ncWLKSdGa1P"
          style="width: 100%; min-height: 600px; border: none; overflow: hidden;"
          scrolling="no"
          title="Book a free KiwiSaver chat"
        ></iframe>
        <script src="https://tr.tilw.co.uk/js/form_embed.js" type="text/javascript"></script>
      </div>
    </div>
  </section>

  <Footer />
</Layout>
