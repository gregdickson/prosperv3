---
import Layout from '../layouts/Layout.astro';
import Nav from '../components/Nav.astro';
import Button from '../components/Button.astro';
import Footer from '../components/Footer.astro';

const steps = [
  {
    number: "1",
    title: "Check my fund (2 minutes)",
    description: "Answer 4 quick questions about your age, goals, provider, and fund type. No jargon, no account logins needed. We'll give you instant personalised insights right there and then.",
    details: [
      "Your age range and life stage",
      "First home buyer status",
      "Current provider and fund type",
      "Instant insight based on your answers",
    ],
  },
  {
    number: "2",
    title: "Strategy review (the first pump)",
    description: "This is where most advisers skip ahead. We start with your strategy — because being in the right fund type matters more than being with the right brand.",
    details: [
      "Contribution rate — are you getting max employer match?",
      "PIR tax rate — heaps of people overpay and don't know it",
      "Fund type alignment for your age, goals, and timeline",
      "First home withdrawal planning (if applicable)",
    ],
  },
  {
    number: "3",
    title: "Provider comparison (the second pump)",
    description: "Once your strategy is sorted, we compare every provider in the market to find the one that fits. No affiliations, no bias — just the numbers.",
    details: [
      "Returns after fees across all providers",
      "Fund options that match your strategy",
      "Platform quality and service",
    ],
  },
  {
    number: "4",
    title: "Personalised recommendation",
    description: "We come back to you with a clear, jargon-free recommendation. If a switch makes sense, we'll explain exactly why. If you're already in a good spot, we'll tell you that too.",
    details: [
      "Clear recommendation with plain-English reasoning",
      "Projected retirement savings or first home deposit amount",
      "No obligation — it's your call",
      "We handle the switch paperwork if you decide to move",
    ],
  },
];
---

<Layout title="How It Works — Prosper">
  <Nav />

  <!-- Hero -->
  <section class="max-w-[1440px] mx-auto px-5 md:px-[40px] mt-[60px] md:mt-[100px] mb-[40px] md:mb-[60px]">
    <div class="text-center max-w-[900px] mx-auto">
      <h1 class="font-tight text-[40px] md:text-[64px] lg:text-[96px] leading-[1.1] uppercase text-dark mb-[20px] md:mb-[40px]">
        The double pump.
      </h1>
      <p class="font-tight text-[20px] md:text-[28px] lg:text-[36px] leading-[1.3] uppercase text-dark">
        Most advisers jump straight to recommending a provider. We do things differently — strategy first, then provider.
      </p>
    </div>
  </section>

  <!-- Steps -->
  <section class="max-w-[1440px] mx-auto px-5 md:px-[40px] mb-[60px] md:mb-[100px]">
    <div class="max-w-[900px] mx-auto">
      {steps.map((step, i) => (
        <div class="flex gap-[20px] md:gap-[40px] mb-[40px] md:mb-[60px]">
          <div class="flex flex-col items-center">
            <div class="w-[48px] h-[48px] md:w-[64px] md:h-[64px] rounded-full bg-dark flex items-center justify-center flex-shrink-0">
              <span class="font-tight text-[24px] md:text-[32px] text-yellow uppercase">{step.number}</span>
            </div>
            {i < steps.length - 1 && (
              <div class="w-[3px] flex-1 bg-dark/20 mt-[16px]"></div>
            )}
          </div>
          <div class="pb-[20px] md:pb-[40px]">
            <h3 class="font-tight text-[24px] md:text-[36px] leading-[1.15] uppercase text-dark mb-[12px] md:mb-[20px]">
              {step.title}
            </h3>
            <p class="font-tight text-[18px] md:text-[24px] leading-[1.3] uppercase text-dark mb-[16px] md:mb-[24px]">
              {step.description}
            </p>
            <ul class="space-y-[8px] md:space-y-[12px]">
              {step.details.map((detail) => (
                <li class="flex items-start gap-[10px]">
                  <span class="font-tight text-[16px] md:text-[20px] text-dark mt-[2px]">-</span>
                  <span class="font-tight text-[16px] md:text-[20px] leading-[1.3] uppercase text-dark/70">{detail}</span>
                </li>
              ))}
            </ul>
          </div>
        </div>
      ))}
    </div>
  </section>

  <!-- Fund Check CTA -->
  <section class="max-w-[1440px] mx-auto px-5 md:px-[40px] mb-[60px] md:mb-[100px]">
    <div class="bg-blue rounded-[6px] px-6 md:px-[60px] lg:px-[115px] py-[40px] md:py-[76px] text-center">
      <h2 class="font-tight text-[36px] md:text-[48px] lg:text-[64px] leading-[1.1] uppercase text-dark mb-[20px] md:mb-[40px]">
        The 15-minute fund check
      </h2>
      <p class="font-tight text-[20px] md:text-[28px] lg:text-[36px] leading-[1.3] uppercase text-dark max-w-[900px] mx-auto mb-[40px] md:mb-[60px]">
        Start with our 2-minute online quiz, then we'll follow up with a quick 15-minute review. No jargon, no pressure, no cost.
      </p>
      <Button label="Check my fund — free" href="/health-check" />
    </div>
  </section>

  <!-- Trust -->
  <section class="max-w-[1440px] mx-auto px-5 md:px-[40px] mb-[60px] md:mb-[100px]">
    <div class="grid grid-cols-1 md:grid-cols-3 gap-[30px] md:gap-[40px]">
      <div class="bg-cream border-[3px] border-dark-alt rounded-[6px] p-6 md:p-10 text-center">
        <h3 class="font-tight text-[28px] md:text-[36px] leading-[1.15] uppercase text-dark mb-[16px] md:mb-[24px]">
          FMA Registered
        </h3>
        <p class="font-tight text-[18px] md:text-[24px] leading-[1.3] uppercase text-dark">
          Licensed financial advice provider, regulated by the FMA.
        </p>
      </div>
      <div class="bg-cream border-[3px] border-dark-alt rounded-[6px] p-6 md:p-10 text-center">
        <h3 class="font-tight text-[28px] md:text-[36px] leading-[1.15] uppercase text-dark mb-[16px] md:mb-[24px]">
          100% Free
        </h3>
        <p class="font-tight text-[18px] md:text-[24px] leading-[1.3] uppercase text-dark">
          Our review costs you nothing. If you switch, the provider pays our fee.
        </p>
      </div>
      <div class="bg-cream border-[3px] border-dark-alt rounded-[6px] p-6 md:p-10 text-center">
        <h3 class="font-tight text-[28px] md:text-[36px] leading-[1.15] uppercase text-dark mb-[16px] md:mb-[24px]">
          Independent
        </h3>
        <p class="font-tight text-[18px] md:text-[24px] leading-[1.3] uppercase text-dark">
          Not affiliated with any provider. Our advice is based on what's best for you.
        </p>
      </div>
    </div>
  </section>

  <Footer />
</Layout>
