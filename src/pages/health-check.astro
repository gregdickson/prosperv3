---
import Layout from '../layouts/Layout.astro';
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';
import HealthCheckWizard from '../components/health-check/HealthCheckWizard.tsx';
---

<Layout title="KiwiSaver Health Check — Prosper">
  <Nav />

  <!-- Hero -->
  <section class="max-w-[1440px] mx-auto px-5 md:px-[40px] mt-[60px] md:mt-[100px] mb-[40px] md:mb-[60px]">
    <div class="text-center max-w-[900px] mx-auto">
      <h1 class="font-tight text-[40px] md:text-[64px] lg:text-[96px] leading-[1.1] uppercase text-dark mb-[20px] md:mb-[40px]">
        How healthy is your KiwiSaver?
      </h1>
      <p class="font-tight text-[20px] md:text-[28px] lg:text-[36px] leading-[1.3] uppercase text-dark">
        Answer a few questions and we'll show you exactly what your KiwiSaver could be worth at 65 — and how much more it could grow with the right setup.
      </p>
    </div>
  </section>

  <!-- Wizard -->
  <section class="max-w-[1440px] mx-auto px-5 md:px-[40px] mb-[60px] md:mb-[100px]">
    <HealthCheckWizard client:load />
  </section>

  <!-- Booking Section -->
  <section id="book" class="max-w-[1440px] mx-auto px-5 md:px-[40px] mb-[60px] md:mb-[100px]">
    <div class="bg-blue rounded-[6px] p-6 md:p-12 lg:p-16">
      <div class="text-center mb-[40px]">
        <h2 class="font-tight text-[36px] md:text-[48px] lg:text-[64px] leading-[1.1] uppercase text-dark mb-[16px]">
          Book your free chat
        </h2>
        <p class="font-tight text-[20px] md:text-[24px] leading-[1.3] uppercase text-dark max-w-[600px] mx-auto">
          Pick a time that works for you. No pressure, no jargon — just a straight-up conversation about your KiwiSaver.
        </p>
      </div>
      <div class="bg-white rounded-[6px] p-4 md:p-6">
        <iframe
          src="https://tr.tilw.co.uk/widget/booking/ClcSvw6h2ncWLKSdGa1P"
          style="width: 100%; min-height: 600px; border: none; overflow: hidden;"
          scrolling="no"
          title="Book a free KiwiSaver chat"
        ></iframe>
        <script src="https://tr.tilw.co.uk/js/form_embed.js" type="text/javascript"></script>
      </div>
    </div>
  </section>

  <!-- Trust badges -->
  <section class="max-w-[1440px] mx-auto px-5 md:px-[40px] mb-[60px] md:mb-[100px]">
    <div class="flex flex-col md:flex-row items-center justify-center gap-6 md:gap-12 font-tight text-[16px] uppercase text-dark/60">
      <div class="flex items-center gap-2">
        <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 15v2m-6 4h12a2 2 0 002-2v-6a2 2 0 00-2-2H6a2 2 0 00-2 2v6a2 2 0 002 2zm10-10V7a4 4 0 00-8 0v4h8z" />
        </svg>
        <span>Your data stays in your browser</span>
      </div>
      <div class="flex items-center gap-2">
        <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z" />
        </svg>
        <span>FMA Registered Adviser</span>
      </div>
      <div class="flex items-center gap-2">
        <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 7h8m0 0v8m0-8l-8 8-4-4-6 6" />
        </svg>
        <span>Morningstar performance data</span>
      </div>
    </div>
  </section>

  <Footer />
</Layout>
