---
import Layout from '../../layouts/Layout.astro';
import Nav from '../../components/Nav.astro';
import Button from '../../components/Button.astro';
import Footer from '../../components/Footer.astro';
import { audiences } from '../../data/audiences';
---

<Layout title="Who We Help — Prosper">
  <Nav />

  <!-- Hero -->
  <section class="max-w-[1440px] mx-auto px-5 md:px-[40px] mt-[60px] md:mt-[100px] mb-[40px] md:mb-[60px]">
    <div class="text-center max-w-[900px] mx-auto">
      <h1 class="font-tight text-[40px] md:text-[64px] lg:text-[96px] leading-[1.1] uppercase text-dark mb-[20px] md:mb-[40px]">
        KiwiSaver advice for your situation.
      </h1>
      <p class="font-tight text-[20px] md:text-[28px] lg:text-[36px] leading-[1.3] uppercase text-dark">
        Different stage of life? Different KiwiSaver needs. Here's how we help people just like you.
      </p>
    </div>
  </section>

  <!-- Segment Cards -->
  <section class="max-w-[1440px] mx-auto px-5 md:px-[40px] mb-[60px] md:mb-[100px]">
    <div class="grid grid-cols-1 md:grid-cols-3 gap-[30px] md:gap-[40px]">
      {audiences.map((audience) => (
        <div class="bg-cream border-[3px] border-dark-alt rounded-[6px] p-6 md:p-10 flex flex-col">
          <h2 class="font-tight text-[28px] md:text-[36px] leading-[1.15] uppercase text-dark mb-[16px] md:mb-[24px]">
            {audience.shortTitle}
          </h2>
          <p class="font-tight text-[18px] md:text-[24px] leading-[1.3] uppercase text-dark mb-[30px] md:mb-[40px] flex-1">
            {audience.description}
          </p>
          <Button label="Learn more" href={`/who-we-help/${audience.slug}`} variant="outline" />
        </div>
      ))}
    </div>
  </section>

  <!-- CTA -->
  <section class="max-w-[1440px] mx-auto px-5 md:px-[40px] mb-[60px] md:mb-[100px]">
    <div class="bg-pink rounded-[6px] px-6 md:px-[60px] lg:px-[115px] py-[40px] md:py-[76px] text-center">
      <h2 class="font-tight text-[36px] md:text-[48px] lg:text-[64px] leading-[1.1] uppercase text-dark mb-[20px] md:mb-[40px]">
        Not sure where you fit?
      </h2>
      <p class="font-tight text-[20px] md:text-[28px] lg:text-[36px] leading-[1.3] uppercase text-dark max-w-[900px] mx-auto mb-[40px] md:mb-[60px]">
        No worries. Our free fund check works for everyone. 2 minutes, zero jargon.
      </p>
      <Button label="Check my fund — free" href="/health-check" />
    </div>
  </section>

  <Footer />
</Layout>
