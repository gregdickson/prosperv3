---
import Layout from '../../layouts/Layout.astro';
import Nav from '../../components/Nav.astro';
import Button from '../../components/Button.astro';
import Footer from '../../components/Footer.astro';
import { audiences } from '../../data/audiences';

const audience = audiences.find((a) => a.slug === 'first-home-buyers')!;
---

<Layout title={`${audience.title} — Prosper`}>
  <Nav />

  <!-- Hero -->
  <section class="max-w-[1440px] mx-auto px-5 md:px-[40px] mt-[60px] md:mt-[100px] mb-[40px] md:mb-[60px]">
    <div class="text-center max-w-[900px] mx-auto">
      <h1 class="font-tight text-[40px] md:text-[64px] lg:text-[96px] leading-[1.1] uppercase text-dark mb-[20px] md:mb-[40px]">
        {audience.heroHeading}
      </h1>
      <p class="font-tight text-[20px] md:text-[28px] lg:text-[36px] leading-[1.3] uppercase text-dark">
        {audience.heroSubtext}
      </p>
    </div>
  </section>

  <!-- Pain Points -->
  <section class="max-w-[1440px] mx-auto px-5 md:px-[40px] mb-[60px] md:mb-[100px]">
    <h2 class="font-tight text-[36px] md:text-[48px] lg:text-[64px] leading-[1.1] uppercase text-dark mb-[30px] md:mb-[50px] text-center">
      {audience.painPoints.heading}
    </h2>
    <div class="grid grid-cols-1 md:grid-cols-3 gap-[30px] md:gap-[40px]">
      {audience.painPoints.items.map((item) => (
        <div class="bg-cream border-[3px] border-dark-alt rounded-[6px] p-6 md:p-10">
          <h3 class="font-tight text-[24px] md:text-[30px] leading-[1.15] uppercase text-dark mb-[16px] md:mb-[24px]">
            {item.title}
          </h3>
          <p class="font-tight text-[18px] md:text-[24px] leading-[1.3] uppercase text-dark">
            {item.description}
          </p>
        </div>
      ))}
    </div>
  </section>

  <!-- Solutions -->
  <section class="max-w-[1440px] mx-auto px-5 md:px-[40px] mb-[60px] md:mb-[100px]">
    <h2 class="font-tight text-[36px] md:text-[48px] lg:text-[64px] leading-[1.1] uppercase text-dark mb-[30px] md:mb-[50px] text-center">
      {audience.solutions.heading}
    </h2>
    <div class="grid grid-cols-1 md:grid-cols-3 gap-[30px] md:gap-[40px]">
      {audience.solutions.items.map((item) => (
        <div class="bg-teal/20 border-[3px] border-dark-alt rounded-[6px] p-6 md:p-10">
          <h3 class="font-tight text-[24px] md:text-[30px] leading-[1.15] uppercase text-dark mb-[16px] md:mb-[24px]">
            {item.title}
          </h3>
          <p class="font-tight text-[18px] md:text-[24px] leading-[1.3] uppercase text-dark">
            {item.description}
          </p>
        </div>
      ))}
    </div>
  </section>

  <!-- CTA -->
  <section class="max-w-[1440px] mx-auto px-5 md:px-[40px] mb-[60px] md:mb-[100px]">
    <div class="bg-orange rounded-[6px] px-6 md:px-[60px] lg:px-[115px] py-[40px] md:py-[76px] text-center">
      <h2 class="font-tight text-[36px] md:text-[48px] lg:text-[64px] leading-[1.1] uppercase text-dark mb-[20px] md:mb-[40px]">
        {audience.ctaHeading}
      </h2>
      <p class="font-tight text-[20px] md:text-[28px] lg:text-[36px] leading-[1.3] uppercase text-dark max-w-[900px] mx-auto mb-[40px] md:mb-[60px]">
        {audience.ctaText}
      </p>
      <Button label={audience.ctaButtonLabel} href="/health-check" />
    </div>
  </section>

  <Footer />
</Layout>
