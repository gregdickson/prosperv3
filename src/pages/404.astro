---
import Layout from '../layouts/Layout.astro';
import Nav from '../components/Nav.astro';
import Button from '../components/Button.astro';
import Footer from '../components/Footer.astro';
---

<Layout title="Page Not Found — Prosper">
  <Nav />

  <section class="max-w-[1440px] mx-auto px-5 md:px-[40px] mt-[100px] md:mt-[160px] mb-[100px] md:mb-[160px] text-center">
    <p class="font-grand-heavy text-[80px] md:text-[120px] lg:text-[160px] leading-[1] text-orange mb-[20px]">404</p>
    <h1 class="font-tight text-[36px] md:text-[48px] lg:text-[64px] leading-[1.1] uppercase text-dark mb-[20px] md:mb-[40px]">
      Oops — wrong turn.
    </h1>
    <p class="font-tight text-[20px] md:text-[28px] lg:text-[36px] leading-[1.3] uppercase text-dark max-w-[700px] mx-auto mb-[40px] md:mb-[60px]">
      This page doesn't exist. But hey, since you're here — might as well check if your KiwiSaver's on track.
    </p>
    <div class="flex flex-col sm:flex-row items-center justify-center gap-[20px] md:gap-[40px]">
      <Button label="Go home" href="/" />
      <Button label="Check my fund" href="/health-check" variant="outline" />
    </div>
  </section>

  <Footer />
</Layout>
