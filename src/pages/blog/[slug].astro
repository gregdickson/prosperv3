---
import Layout from '../../layouts/Layout.astro';
import Nav from '../../components/Nav.astro';
import Button from '../../components/Button.astro';
import Footer from '../../components/Footer.astro';
import { getCollection, render } from 'astro:content';

export async function getStaticPaths() {
  const posts = await getCollection('blog');
  return posts.map((post) => ({
    params: { slug: post.id },
    props: { post },
  }));
}

const { post } = Astro.props;
const { Content } = await render(post);
---

<Layout title={`${post.data.title} — Prosper`}>
  <Nav />

  <!-- Article Header -->
  <section class="max-w-[1440px] mx-auto px-5 md:px-[40px] mt-[60px] md:mt-[100px] mb-[40px] md:mb-[60px]">
    <div class="max-w-[800px] mx-auto">
      <a href="/blog" class="font-tight text-[16px] md:text-[20px] uppercase text-dark/50 hover:text-dark transition-colors mb-[20px] md:mb-[30px] inline-block">
        &larr; Back to resources
      </a>
      <div class="flex items-center gap-[16px] mb-[20px] md:mb-[30px]">
        <span class="font-tight text-[14px] md:text-[16px] uppercase text-dark/50">{post.data.category}</span>
        <span class="text-dark/30">|</span>
        <span class="font-tight text-[14px] md:text-[16px] uppercase text-dark/50">
          {post.data.pubDate.toLocaleDateString('en-NZ', { day: 'numeric', month: 'long', year: 'numeric' })}
        </span>
      </div>
      <h1 class="font-tight text-[36px] md:text-[48px] lg:text-[64px] leading-[1.1] uppercase text-dark mb-[20px] md:mb-[40px]">
        {post.data.title}
      </h1>
      <p class="font-tight text-[20px] md:text-[28px] leading-[1.3] uppercase text-dark/70">
        {post.data.description}
      </p>
    </div>
  </section>

  <!-- Article Content -->
  <section class="border-y-[6px] border-dark-alt bg-cream mb-[60px] md:mb-[100px]">
    <div class="max-w-[1440px] mx-auto px-5 md:px-[40px] py-[40px] md:py-[76px]">
      <div class="max-w-[800px] mx-auto prose-prosper">
        <Content />
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="max-w-[1440px] mx-auto px-5 md:px-[40px] mb-[60px] md:mb-[100px]">
    <div class="bg-blue rounded-[6px] px-6 md:px-[60px] lg:px-[115px] py-[40px] md:py-[76px] text-center">
      <h2 class="font-tight text-[36px] md:text-[48px] lg:text-[64px] leading-[1.1] uppercase text-dark mb-[20px] md:mb-[40px]">
        Ready to check yours?
      </h2>
      <p class="font-tight text-[20px] md:text-[28px] leading-[1.3] uppercase text-dark max-w-[700px] mx-auto mb-[40px] md:mb-[60px]">
        Our free health check takes 2 minutes and shows you exactly where your KiwiSaver stands.
      </p>
      <Button label="Check my fund" href="/health-check" />
    </div>
  </section>

  <Footer />
</Layout>

<style is:global>
  .prose-prosper h2 {
    font-family: "Agrandir Tight", sans-serif;
    font-size: 28px;
    line-height: 1.15;
    text-transform: uppercase;
    color: #1c1b19;
    margin-top: 48px;
    margin-bottom: 20px;
  }
  .prose-prosper h3 {
    font-family: "Agrandir Tight", sans-serif;
    font-size: 22px;
    line-height: 1.15;
    text-transform: uppercase;
    color: #1c1b19;
    margin-top: 36px;
    margin-bottom: 16px;
  }
  .prose-prosper p {
    font-family: "Agrandir Tight", sans-serif;
    font-size: 20px;
    line-height: 1.4;
    text-transform: uppercase;
    color: #1c1b19;
    margin-bottom: 20px;
  }
  .prose-prosper ul, .prose-prosper ol {
    font-family: "Agrandir Tight", sans-serif;
    font-size: 20px;
    line-height: 1.4;
    text-transform: uppercase;
    color: #1c1b19;
    margin-bottom: 20px;
    padding-left: 24px;
  }
  .prose-prosper li {
    margin-bottom: 8px;
  }
  .prose-prosper strong {
    font-family: "Agrandir TextBold", sans-serif;
  }
  .prose-prosper a {
    color: #1c1b19;
    text-decoration: underline;
    text-underline-offset: 3px;
  }
  .prose-prosper a:hover {
    opacity: 0.7;
  }
  @media (min-width: 768px) {
    .prose-prosper h2 { font-size: 36px; margin-top: 60px; margin-bottom: 24px; }
    .prose-prosper h3 { font-size: 28px; margin-top: 48px; margin-bottom: 20px; }
    .prose-prosper p, .prose-prosper ul, .prose-prosper ol { font-size: 24px; }
  }
</style>
