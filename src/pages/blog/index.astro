---
import Layout from '../../layouts/Layout.astro';
import Nav from '../../components/Nav.astro';
import Button from '../../components/Button.astro';
import Footer from '../../components/Footer.astro';
import { getCollection } from 'astro:content';

const posts = (await getCollection('blog'))
  .filter((post) => !post.data.draft)
  .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());
---

<Layout title="Resources — Prosper">
  <Nav />

  <!-- Hero -->
  <section class="max-w-[1440px] mx-auto px-5 md:px-[40px] mt-[60px] md:mt-[100px] mb-[40px] md:mb-[60px]">
    <div class="text-center max-w-[900px] mx-auto">
      <h1 class="font-tight text-[40px] md:text-[64px] lg:text-[96px] leading-[1.1] uppercase text-dark mb-[20px] md:mb-[40px]">
        KiwiSaver guides & straight talk.
      </h1>
      <p class="font-tight text-[20px] md:text-[28px] lg:text-[36px] leading-[1.3] uppercase text-dark">
        No finance jargon. No fluff. Just useful stuff to help you make better decisions about your retirement savings.
      </p>
    </div>
  </section>

  <!-- Posts Grid -->
  <section class="max-w-[1440px] mx-auto px-5 md:px-[40px] mb-[60px] md:mb-[100px]">
    {posts.length > 0 ? (
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-[30px] md:gap-[40px]">
        {posts.map((post) => (
          <a href={`/blog/${post.id}`} class="group bg-cream border-[3px] border-dark-alt rounded-[6px] p-6 md:p-10 flex flex-col hover:bg-dark hover:text-yellow transition-colors">
            <span class="font-tight text-[14px] md:text-[16px] uppercase text-dark/50 group-hover:text-yellow/60 mb-[12px]">
              {post.data.category}
            </span>
            <h2 class="font-tight text-[24px] md:text-[30px] leading-[1.15] uppercase text-dark group-hover:text-yellow mb-[16px] md:mb-[24px]">
              {post.data.title}
            </h2>
            <p class="font-tight text-[18px] md:text-[22px] leading-[1.3] uppercase text-dark/70 group-hover:text-yellow/70 mb-[20px] flex-1">
              {post.data.description}
            </p>
            <span class="font-tight text-[14px] md:text-[16px] uppercase text-dark/40 group-hover:text-yellow/50">
              {post.data.pubDate.toLocaleDateString('en-NZ', { day: 'numeric', month: 'long', year: 'numeric' })}
            </span>
          </a>
        ))}
      </div>
    ) : (
      <p class="font-tight text-[24px] uppercase text-dark/50 text-center">Posts coming soon. Watch this space.</p>
    )}
  </section>

  <Footer />
</Layout>
